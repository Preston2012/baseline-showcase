graph TB
    subgraph Client["Flutter Mobile App (28 screens)"]
        Feed[Statement Feed]
        Profile[Figure Profiles]
        Bills[Legislative Tracker]
        Trends[Trends Dashboard]
        Settings[Account and Settings]
    end

    subgraph Supabase["Supabase (PostgreSQL 17 + RLS on all 30 tables)"]
        DB[(30 Tables)]
        Auth[Auth + RLS]
        RT[Realtime]
    end

    subgraph Ingestion["Ingestion Pipeline"]
        n8n[n8n Workflows]
        MIT[manual-ingest-trigger]
        SH[Source Hashing + Dedup]
        BB[backfill-baseline]
    end

    subgraph Extraction["Extraction (Gemini)"]
        GSO[gemini-structured-output]
    end

    subgraph Analysis["Multi-Provider Analysis (parallel)"]
        AS[analyze-statement]
        CL_COST[cost-log]
    end

    subgraph Providers["3 Analysis Providers (independent)"]
        Claude[Claude - Anthropic]
        GPT[GPT-4 - OpenAI]
        Grok[Grok - xAI]
    end

    subgraph Consensus["Consensus Engine"]
        CC[compute-consensus]
        VD[Variance Detection]
        OD[Outlier Flagging]
    end

    subgraph Enrichment["Enrichment + Scoring"]
        GBS[get-baseline-score]
        GE[generate-embedding]
        GNS[get-narrative-sync]
    end

    subgraph Legislative["Legislative Tracking"]
        Congress[Congress.gov API]
        SBV[sync-bill-versions]
        IBV[ingest-bill-version]
        CBM[compute-bill-mutation]
        SB[summarize-bill]
    end

    subgraph DataAPI["Data API Layer"]
        GF[get-feed - smart ranking]
        GS[get-statement]
        GFP[get-figure-profile]
        GT[get-trends]
        GV[get-votes]
    end

    subgraph Platform["Platform Services"]
        CE[check-entitlement]
        RCW[revenuecat-webhook]
        AN[annotations]
        MA[manage-account]
        RC[RevenueCat]
    end

    Make --> Ingestion
    Ingestion --> DB
    DB --> Extraction
    Extraction --> DB
    DB --> AS
    AS --> Claude
    AS --> GPT
    AS --> Grok
    AS --> CL_COST
    Claude --> CC
    GPT --> CC
    Grok --> CC
    CC --> VD
    CC --> OD
    CC --> DB
    DB --> Enrichment
    Enrichment --> DB
    Congress --> SBV
    SBV --> IBV
    IBV --> CBM
    CBM --> SB
    Legislative --> DB
    Client --> Auth
    Auth --> DataAPI
    Auth --> Platform
    DataAPI --> DB
    RC --> RCW
    RCW --> DB

    style Client fill:#1E1E2E,stroke:#6C63FF,color:#fff
    style Supabase fill:#1a3a2a,stroke:#3ECF8E,color:#fff
    style Ingestion fill:#1a2a3a,stroke:#38bdf8,color:#fff
    style Extraction fill:#2a2a1a,stroke:#fbbf24,color:#fff
    style Analysis fill:#1a2a3a,stroke:#38bdf8,color:#fff
    style Providers fill:#2a1a3a,stroke:#a78bfa,color:#fff
    style Consensus fill:#2a1a3a,stroke:#a78bfa,color:#fff
    style Enrichment fill:#1a2a3a,stroke:#38bdf8,color:#fff
    style Legislative fill:#2a2a1a,stroke:#fbbf24,color:#fff
    style DataAPI fill:#1a2a3a,stroke:#38bdf8,color:#fff
    style Platform fill:#1E1E2E,stroke:#6C63FF,color:#fff
