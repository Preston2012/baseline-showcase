# Baseline Environment Variables
# Copy to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AI...
XAI_API_KEY=xai-...

# Congress.gov
CONGRESS_API_KEY=your-congress-api-key

# RevenueCat
REVENUECAT_API_KEY=your-revenuecat-key
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# n8n (automation webhooks)
N8N_WEBHOOK_INGEST=https://your-n8n-instance.com/webhook/...
N8N_WEBHOOK_BACKFILL=https://your-n8n-instance.com/webhook/...